---
import Layout from "@layouts/Layout.astro";
import ProjectCard from "@components/projects/section/ProjectCard.svelte";
import { getCollection, type CollectionEntry } from "astro:content";

const projects = (await getCollection("projects")) as CollectionEntry<"projects">[];

const sortedProjects = projects.sort(
	(a, b) => Number(b.data.pubYear) - Number(a.data.pubYear)
);

const featuredProject = sortedProjects[0];
const secondaryProjects = sortedProjects.slice(1);
---

<Layout
	title="0b | Projects"
	description="Selected case studies and projects by Kevin Bravo."
>
	<div class="section-container min-h-screen py-16">
		<div class="mb-16">
			<a href="/" class="inline-flex text-xs font-medium text-surface-400 dark:text-surface-500 hover:text-surface-900 dark:hover:text-surface-200 transition-colors mb-8">
				&larr; Home
			</a>
			<h1 class="text-4xl font-bold tracking-tighter text-surface-900 dark:text-surface-100 mb-3">Projects</h1>
			<p class="text-surface-500 dark:text-surface-400 max-w-xl">
				An evolving archive of my software engineering journey. From early product experiments to production-grade applications, exploring technical challenges, architectures, and lessons learned.
			</p>
		</div>

		<div class="mb-16">
			<div class="flex items-center justify-between mb-8 pb-4 border-b border-surface-200 dark:border-surface-800">
				<span class="text-xs font-medium uppercase tracking-widest text-surface-400 dark:text-surface-500">Featured</span>
			</div>
			
			{featuredProject && (
				<a
					href={`/projects/${featuredProject.id}`}
					class="group block w-full outline-none"
				>
					<article class="flex flex-col gap-8 md:flex-row md:items-center">
						<div class="relative w-full md:w-[60%] aspect-[16/10] md:aspect-video overflow-hidden rounded-xl bg-surface-100 dark:bg-surface-800 ring-1 ring-surface-200/50 dark:ring-surface-700/50">
							<img
								src={featuredProject.data.image.url}
								alt={featuredProject.data.image.alt}
								class="h-full w-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-[1.03]"
							/>
							<div class="absolute inset-0 bg-surface-900/0 transition-colors duration-500 group-hover:bg-surface-900/5 dark:group-hover:bg-surface-900/20"></div>
							<div class="absolute left-6 top-6">
								<span class="inline-flex items-center justify-center rounded-full bg-white/95 px-4 py-1.5 text-[11px] font-bold uppercase tracking-widest text-surface-900 shadow-sm backdrop-blur-md dark:bg-surface-950/90 dark:text-surface-100">
									Featured
								</span>
							</div>
						</div>

						<div class="flex flex-col flex-1 gap-4 md:pl-8">
							<div class="flex items-center gap-3 text-xs tracking-wide text-surface-500 dark:text-surface-400">
								<span class="font-medium text-surface-900 dark:text-surface-200">{featuredProject.data.pubYear.getFullYear()}</span>
								<span class="h-1 w-1 rounded-full bg-surface-300 dark:bg-surface-700"></span>
								<div class="flex gap-2">
									{featuredProject.data.tags.slice(0,3).map((tag) => (
										<span class="capitalize">{tag}</span>
									))}
								</div>
							</div>
							
							<div>
								<h2 class="flex items-center gap-3 text-3xl md:text-3xl lg:text-4xl font-bold tracking-tight text-surface-900 transition-colors duration-300 group-hover:text-accent-600 dark:text-surface-100 dark:group-hover:text-accent-400">
									{featuredProject.data.title}
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="translate-y-2 -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:translate-y-0 group-hover:opacity-100"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
								</h2>
								<p class="mt-4 text-base leading-relaxed text-surface-600 dark:text-surface-400 max-w-md">
									{featuredProject.data.description}
								</p>
							</div>
							
							<div class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-accent-500 transition-colors group-hover:text-accent-600 dark:text-accent-400">
								Read case study
								<svg class="transition-transform duration-300 group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
							</div>
						</div>
					</article>
				</a>
			)}
		</div>

		<div class="mb-16">
			<div class="flex items-center justify-between mb-8 pb-4 border-b border-surface-200 dark:border-surface-800">
				<span class="text-xs font-medium uppercase tracking-widest text-surface-400 dark:text-surface-500">All Projects</span>
				<span class="text-xs text-surface-400 dark:text-surface-500">{secondaryProjects.length} remaining</span>
			</div>
			<div class="grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
				{secondaryProjects.map((project) => <ProjectCard project={project} />)}
			</div>
		</div>
	</div>
</Layout>