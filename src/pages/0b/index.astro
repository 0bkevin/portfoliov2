---
import Layout from "@layouts/Layout.astro";
import { type CollectionEntry, getCollection } from "astro:content";
import { formatDateToDisplay, getReadingTime } from "../../lib/utils";

const blogs = (await getCollection("blogs")) as CollectionEntry<"blogs">[];

const sortedPost = blogs.sort(
  (a, b) => Number(new Date(b.data.pubDate)) - Number(new Date(a.data.pubDate))
);
---

<Layout
  title="0b | Kevin Bravo's blog"
  description="Kevin Bravo's blog. Read about software development, maths, blockchain, security and embedded systems."
>
  <div class="blog-container py-16 min-h-screen">
    <div class="mb-16">
      <a href="/" class="inline-flex text-xs font-medium text-surface-400 dark:text-surface-500 hover:text-surface-900 dark:hover:text-surface-200 transition-colors mb-8">
        &larr; Home
      </a>
      <h1 class="text-4xl font-bold tracking-tighter text-surface-900 dark:text-surface-100 mb-3">Blog</h1>
      <p class="text-surface-500 dark:text-surface-400">
        Writing about software development, blockchain, security, and systems.
      </p>
    </div>

    <!-- Search & Sort Controls -->
    <div class="flex flex-col sm:flex-row gap-3 mb-10">
      <div class="relative flex-1 group">
        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-surface-400 group-focus-within:text-accent-500 transition-colors">
          <svg class="w-[18px] h-[18px]" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <input 
          type="search" 
          id="blog-search" 
          class="block w-full py-2.5 pl-11 pr-4 text-[14px] rounded-lg bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 text-surface-900 dark:text-surface-100 placeholder:text-surface-400 dark:placeholder:text-surface-600 focus:outline-none focus:ring-2 focus:ring-accent-500/20 focus:border-accent-500/50 transition-all hover:border-surface-300 dark:hover:border-surface-700" 
          placeholder="Search posts..." 
        />
      </div>
      <div class="relative shrink-0 group">
        <select 
          id="blog-sort" 
          class="appearance-none block w-full sm:w-[160px] py-2.5 pl-4 pr-10 text-[14px] rounded-lg bg-surface-50 dark:bg-surface-900 border border-surface-200 dark:border-surface-800 text-surface-900 dark:text-surface-100 focus:outline-none focus:ring-2 focus:ring-accent-500/20 focus:border-accent-500/50 transition-all hover:border-surface-300 dark:hover:border-surface-700 cursor-pointer"
        >
          <option value="newest" class="bg-white dark:bg-surface-900">Newest first</option>
          <option value="oldest" class="bg-white dark:bg-surface-900">Oldest first</option>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-surface-400 group-focus-within:text-accent-500 transition-colors">
          <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
          </svg>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between mb-8 pb-4 border-b border-surface-200 dark:border-surface-800">
      <span class="text-xs font-medium uppercase tracking-widest text-surface-400 dark:text-surface-500">All Posts</span>
      <span class="text-xs text-surface-400 dark:text-surface-500" id="post-count">{blogs.length} posts</span>
    </div>

    <ul class="space-y-0" id="blog-list">
      {
        sortedPost.map((blog) => (
          <li class="blog-post-item" data-title={blog.data.title.toLowerCase()} data-date={new Date(blog.data.pubDate).getTime()}>
            <a
              href={`/0b/${blog.id}`}
              class="group flex flex-col md:flex-row md:items-center md:justify-between py-4 border-b border-surface-100 dark:border-surface-800/50 hover:pl-2 transition-all"
            >
              <h2 class="text-sm font-medium text-surface-800 dark:text-surface-200 group-hover:text-surface-900 dark:group-hover:text-surface-100 transition-colors">
                {blog.data.title}
              </h2>
              <div class="flex gap-3 items-center text-xs text-surface-400 dark:text-surface-500 shrink-0 mt-1 md:mt-0">
                <span>{formatDateToDisplay(blog.data.pubDate)}</span>
                <span class="w-px h-3 bg-surface-200 dark:bg-surface-800"></span>
                <span>{getReadingTime(blog.body)} min</span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    
    <div id="no-results" class="hidden py-8 text-center text-surface-500 dark:text-surface-400">
      No posts found matching your search.
    </div>
  </div>
</Layout>

<script>
  function initBlogFilter() {
    const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
    const sortSelect = document.getElementById('blog-sort') as HTMLSelectElement | null;
    const blogList = document.getElementById('blog-list');
    const noResults = document.getElementById('no-results');
    const postCount = document.getElementById('post-count');
    
    if (!searchInput || !sortSelect || !blogList || !noResults || !postCount) return;

    const posts = Array.from(blogList.querySelectorAll('.blog-post-item')) as HTMLElement[];

    function updateList() {
      if (!searchInput || !sortSelect || !blogList || !noResults || !postCount) return;

      const searchTerm = searchInput.value.toLowerCase().trim();
      const sortValue = sortSelect.value;
      let visibleCount = 0;

      // Filter and count visible posts
      posts.forEach(post => {
        const title = post.getAttribute('data-title') || '';
        const matches = title.includes(searchTerm);
        
        if (matches) {
          post.style.display = '';
          visibleCount++;
        } else {
          post.style.display = 'none';
        }
      });

      // Sort ALL posts to maintain consistent DOM order
      posts.sort((a, b) => {
        const dateA = parseInt(a.getAttribute('data-date') || '0', 10);
        const dateB = parseInt(b.getAttribute('data-date') || '0', 10);
        
        if (sortValue === 'newest') {
          return dateB - dateA;
        } else {
          return dateA - dateB;
        }
      });

      // Reorder DOM
      posts.forEach(post => blogList.appendChild(post));

      // Update UI state
      postCount.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''}`;
      
      if (visibleCount === 0) {
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
      }
    }

    searchInput.addEventListener('input', updateList);
    sortSelect.addEventListener('change', updateList);
  }

  // Initialize on load and when navigating via ViewTransitions if used
  document.addEventListener('astro:page-load', initBlogFilter);
  // Also run immediately in case ViewTransitions are not used
  initBlogFilter();
</script>
