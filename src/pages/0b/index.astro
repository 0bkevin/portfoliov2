---
import Layout from "@layouts/Layout.astro";
import { type CollectionEntry, getCollection } from "astro:content";
import { formatDateToDisplay, getReadingTime } from "../../lib/utils";
import {
  createBreadcrumbSchema,
  createCollectionPageSchema,
  createPersonSchema,
  createWebsiteSchema,
  seoConfig,
} from "@lib/seo";

const blogs = (await getCollection("blogs")) as CollectionEntry<"blogs">[];

const sortedPost = blogs.sort(
  (a, b) => Number(new Date(b.data.pubDate)) - Number(new Date(a.data.pubDate))
);

const pageTitle = "Backend, Infrastructure, AI & Full-Stack Articles | Kevin Bravo";
const pageDescription =
  "Explore practical articles by Kevin Bravo on backend engineering, infrastructure, AI engineering, full-stack systems, blockchain, and security.";

const structuredData = [
  createWebsiteSchema(),
  createCollectionPageSchema({
    name: "0b Blog",
    url: `${seoConfig.siteUrl}/0b`,
    description: pageDescription,
    about: [
      "Software engineering",
      "Backend systems",
      "Blockchain",
      "Security",
      "Engineering leadership",
    ],
  }),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Kevin Bravo technical articles",
    itemListOrder: "https://schema.org/ItemListOrderDescending",
    numberOfItems: sortedPost.length,
    itemListElement: sortedPost.map((blog, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/0b/${blog.id}`, Astro.site).toString(),
      name: blog.data.title,
      description: blog.data.description,
    })),
  },
  createBreadcrumbSchema([
    { name: "Home", item: "/" },
    { name: "Blog", item: "/0b" },
  ]),
  createPersonSchema({
    mainEntityOfPage: `${seoConfig.siteUrl}/0b`,
  }),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="/0b"
  image={seoConfig.defaultOgImage}
  imageAlt={seoConfig.defaultOgImageAlt}
  type="website"
  structuredData={structuredData}
>
  <div class="blog-container pt-4 pb-16 min-h-screen">
    <header class="mb-16">
      <a
        href="/"
        class="inline-flex text-xs font-medium text-surface-400 dark:text-surface-500 hover:text-surface-900 dark:hover:text-surface-200 transition-colors mb-8"
      >
        &larr; Home
      </a>
      <h1 class="text-4xl font-bold tracking-tighter text-surface-900 dark:text-surface-100 mb-3">
        Blog
      </h1>
      <p class="text-surface-500 dark:text-surface-400 max-w-2xl">
        Writing about backend systems, infrastructure, AI engineering, full-stack
        software, blockchain, security, and the engineering decisions behind
        production-ready systems.
      </p>
    </header>

    <section aria-labelledby="blog-controls-heading" class="sr-only">
      <h2 id="blog-controls-heading">Blog controls</h2>
    </section>

    <div class="flex flex-col sm:flex-row sm:items-end gap-3 mb-12">
      <div class="relative flex-1 group">
        <label for="blog-search" class="sr-only">Search blog posts</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-surface-400 group-focus-within:text-accent-500 dark:group-focus-within:text-accent-400 transition-colors">
          <svg
            class="w-4 h-4"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
            />
          </svg>
        </div>
        <input
          type="search"
          id="blog-search"
          class="block w-full py-2 pl-11 pr-4 text-sm rounded-lg bg-transparent border border-surface-200 dark:border-surface-800 text-surface-900 dark:text-surface-100 placeholder:text-surface-400 dark:placeholder:text-surface-600 focus:outline-none focus:border-accent-500/60 dark:focus:border-accent-400/60 hover:border-surface-300 dark:hover:border-surface-700 transition-colors"
          placeholder="Search posts..."
          autocomplete="off"
        />
      </div>

      <div class="flex flex-col gap-1.5 shrink-0">
        <span class="text-[10px] font-medium uppercase tracking-widest text-surface-400 dark:text-surface-500 pl-0.5">
          Sort
        </span>
        <button
          id="blog-sort-button"
          type="button"
          class="inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-surface-600 dark:text-surface-400 border border-surface-200 dark:border-surface-800 rounded-lg hover:border-surface-300 dark:hover:border-surface-700 hover:text-surface-900 dark:hover:text-surface-200 transition-colors cursor-pointer group/btn"
          data-sort="newest"
          aria-label="Toggle post sort order"
        >
          <span id="sort-text">Newest</span>
          <svg
            id="sort-icon"
            class="w-3.5 h-3.5 text-surface-400 group-hover/btn:text-surface-600 dark:group-hover/btn:text-surface-300 transition-transform"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              id="sort-path"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5"
            />
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 16.5L16.5 21m0 0L12 16.5m4.5 4.5V7.5"
            />
          </svg>
        </button>
      </div>
    </div>

    <div class="flex items-center justify-between mb-8 pb-4 border-b border-surface-200 dark:border-surface-800">
      <span class="text-xs font-medium uppercase tracking-widest text-surface-400 dark:text-surface-500">
        All Posts
      </span>
      <span class="text-xs text-surface-400 dark:text-surface-500" id="post-count">
        {blogs.length} posts
      </span>
    </div>

    <section aria-labelledby="all-posts-heading">
      <h2 id="all-posts-heading" class="sr-only">All blog posts</h2>

      <ul class="space-y-0" id="blog-list">
        {
          sortedPost.map((blog) => (
            <li
              class="blog-post-item"
              data-title={blog.data.title.toLowerCase()}
              data-date={new Date(blog.data.pubDate).getTime()}
            >
              <a
                href={`/0b/${blog.id}`}
                class="group flex flex-col md:flex-row md:items-center md:justify-between py-4 border-b border-surface-100 dark:border-surface-800/50 hover:pl-2 transition-all"
              >
                <div class="min-w-0">
                  <h3 class="text-sm font-medium text-surface-800 dark:text-surface-200 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
                    {blog.data.title}
                  </h3>
                  <p class="mt-1 max-w-2xl text-sm leading-relaxed text-surface-500 dark:text-surface-400">
                    {blog.data.description}
                  </p>
                </div>

                <div class="flex gap-3 items-center text-xs text-surface-400 dark:text-surface-500 shrink-0 mt-2 md:mt-0">
                  <time datetime={new Date(blog.data.pubDate).toISOString()}>
                    {formatDateToDisplay(blog.data.pubDate)}
                  </time>
                  <span class="w-px h-3 bg-surface-200 dark:bg-surface-800"></span>
                  <span>{getReadingTime(blog.body)} min</span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <div
      id="no-results"
      class="hidden py-8 text-center text-surface-500 dark:text-surface-400"
      role="status"
      aria-live="polite"
    >
      No posts found matching your search.
    </div>
  </div>
</Layout>

<script>
  function initBlogFilter() {
    const searchInput = document.getElementById("blog-search") as HTMLInputElement | null;
    const sortBtn = document.getElementById("blog-sort-button") as HTMLButtonElement | null;
    const sortText = document.getElementById("sort-text");
    const sortIcon = document.getElementById("sort-icon") as HTMLElement | null;
    const blogList = document.getElementById("blog-list") as HTMLElement | null;
    const noResults = document.getElementById("no-results") as HTMLElement | null;
    const postCount = document.getElementById("post-count") as HTMLElement | null;

    if (!searchInput || !sortBtn || !blogList || !noResults || !postCount) {
      return;
    }

    const posts = Array.from(blogList.querySelectorAll(".blog-post-item")) as HTMLElement[];
    let currentSort: "newest" | "oldest" = "newest";

    function updateList() {
      const searchTerm = searchInput!.value.toLowerCase().trim();
      let visibleCount = 0;

      posts.forEach((post) => {
        const title = post.getAttribute("data-title") || "";
        const matches = title.includes(searchTerm);

        if (matches) {
          post.style.display = "";
          visibleCount++;
        } else {
          post.style.display = "none";
        }
      });

      posts.sort((a, b) => {
        const dateA = parseInt(a.getAttribute("data-date") || "0", 10);
        const dateB = parseInt(b.getAttribute("data-date") || "0", 10);

        return currentSort === "newest" ? dateB - dateA : dateA - dateB;
      });

      posts.forEach((post) => blogList!.appendChild(post));

      postCount!.textContent = `${visibleCount} post${visibleCount !== 1 ? "s" : ""}`;
      noResults!.classList.toggle("hidden", visibleCount !== 0);
    }

    sortBtn.addEventListener("click", () => {
      currentSort = currentSort === "newest" ? "oldest" : "newest";

      if (sortText) {
        sortText.textContent = currentSort === "newest" ? "Newest" : "Oldest";
      }

      if (sortIcon) {
        sortIcon.style.transform =
          currentSort === "newest" ? "rotate(0deg)" : "rotate(180deg)";
      }

      updateList();
    });

    searchInput.addEventListener("input", updateList);
  }

  document.addEventListener("astro:page-load", initBlogFilter);
  initBlogFilter();
</script>
