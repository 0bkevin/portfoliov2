---
import BlogLayout from "@layouts/Blog.astro";
import { type CollectionEntry, getCollection, render } from "astro:content";
import {
  createArticleSchema,
  createBreadcrumbSchema,
  createPersonSchema,
  createProfilePageSchema,
  seoConfig,
} from "@lib/seo";

export const prerender = true;

// called at build time, it compiles the list of all possible paths for this page to make it static
export async function getStaticPaths() {
  const posts = (await getCollection("me")) as CollectionEntry<"me">[];

  return posts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"me">;
}

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);

const pathname = `/me/${entry.id}`;
const pageUrl = new URL(pathname, Astro.site).toString();
const imageUrl = entry.data.image?.url || seoConfig.defaultOgImage;
const updatedDate = entry.data.updateDate ?? entry.data.pubDate;
const noindex = entry.id === "who-is-kevin-bravo";
const seoTitle =
  entry.id === "ama"
    ? "Kevin Bravo | Backend, Infrastructure, AI & Full-Stack Engineer"
    : entry.data.seoTitle;
const seoDescription =
  entry.id === "ama"
    ? "Learn about Kevin Bravo's backend, infrastructure, AI engineering, and full-stack software work, including technical strengths, project ownership, and career fit."
    : entry.data.seoDescription;

const articleSchema = createArticleSchema({
  headline: entry.data.title,
  description: entry.data.description,
  url: pageUrl,
  image: imageUrl,
  datePublished: entry.data.pubDate,
  dateModified: updatedDate,
  authorName: seoConfig.author.name,
  authorUrl: seoConfig.author.url,
  inLanguage: "en",
});

const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", item: "/" },
  { name: "Profile", item: "/me/ama" },
  { name: entry.data.title, item: pathname },
]);

const personSchema = createPersonSchema({
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  description: seoDescription || entry.data.description,
  image: new URL(imageUrl, Astro.site).toString(),
});

const profilePageSchema =
  entry.id === "ama"
    ? createProfilePageSchema({
        name: seoTitle || entry.data.title,
        description: seoDescription || entry.data.description,
        url: pageUrl,
      })
    : undefined;

const structuredData = [
  articleSchema,
  breadcrumbSchema,
  personSchema,
  ...(profilePageSchema ? [profilePageSchema] : []),
];
---

<BlogLayout
  entry={entry}
  tableOfContents={headings}
  backHref="/"
  backLabel="Home"
  showAuthor={true}
  sectionLabel="Profile"
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  type="profile"
  canonical={pathname}
  structuredData={structuredData}
  noindex={noindex}
  hideSectionLabel={true}
>
  <Content />
</BlogLayout>
