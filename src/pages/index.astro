---
import Layout from "../layouts/Layout.astro";
import Home from "../components/home/Home.astro";
import About from "../components/about/About.astro";
import ExperienceSection from "../components/experience/ExperienceSection.astro";
import ScrollUp from "../components/ScrollUp.astro";
import Contact from "../components/contact/Contact.astro";
import ProjectsSection from "../components/projects/section/ProjectsSection.astro";
import BlogSection from "../components/blog/section/BlogSection.astro";
import AchievementsSection from "../components/achievements/AchievementsSection.astro";
import { createPersonSchema, createWebsiteSchema, seoConfig } from "@lib/seo";

const title = "Kevin Bravo | Backend, Infrastructure, AI & Full-Stack Engineer";
const description =
  "Explore Kevin Bravo's software engineering portfolio, case studies, and technical writing on backend systems, infrastructure, AI engineering, and full-stack product work.";
const image = seoConfig.defaultOgImage;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${seoConfig.siteUrl}/#webpage`,
  name: title,
  description,
  url: Astro.url.toString(),
  isPartOf: {
    "@type": "WebSite",
    "@id": `${seoConfig.siteUrl}/#website`,
    name: seoConfig.siteName,
    url: seoConfig.siteUrl,
  },
  about: {
    "@type": "Person",
    "@id": `${seoConfig.siteUrl}/#person`,
    name: seoConfig.author.name,
    url: seoConfig.author.url,
    jobTitle: seoConfig.author.jobTitle,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: new URL(image, Astro.site).toString(),
  },
};

const websiteSchema = createWebsiteSchema({
  name: seoConfig.siteName,
  url: seoConfig.siteUrl,
  description,
});

const personSchema = createPersonSchema({
  description:
    "Software engineer focused on backend systems, infrastructure, AI engineering, full-stack products, and product delivery.",
  worksFor: [
    {
      "@type": "Organization",
      name: "Proyecto Educa",
    },
  ],
  knowsAbout: [
    "Backend engineering",
    "Infrastructure",
    "AI engineering",
    "Full-stack engineering",
    "Product engineering",
    "Data systems",
    "Blockchain security",
  ],
});

const structuredData = [websiteSchema, personSchema, webPageSchema];
---

<Layout
  title={title}
  description={description}
  image={image}
  imageAlt="Portrait of Kevin Bravo, backend, infrastructure, AI, and full-stack software engineer"
  canonical="/"
  type="website"
  structuredData={structuredData}
>
  <Home />
  <About />
  <ExperienceSection />
  <ProjectsSection />
  <AchievementsSection />
  <BlogSection />
  <Contact />
  <ScrollUp />
</Layout>
