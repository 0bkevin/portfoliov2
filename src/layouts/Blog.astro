---
import Layout from "./Layout.astro";
import { formatDateToDisplay, getReadingTime } from "@lib/utils";
import type { CollectionEntry } from "astro:content";
import Toc from "@components/Toc/Toc.svelte";
import ScrollUp from "../components/ScrollUp.astro";

type ContentEntry = CollectionEntry<"blogs"> | CollectionEntry<"me">;
type TableOfContentsHeading = { text: string; depth: number; slug: string };
type TocItem = { text: string; level: number; id: string };

interface Props {
  entry: ContentEntry;
  tableOfContents: TableOfContentsHeading[];
  backHref?: string | undefined;
  backLabel?: string | undefined;
  showAuthor?: boolean | undefined;
  sectionLabel?: string | undefined;
  seoTitle?: string | undefined;
  seoDescription?: string | undefined;
  canonical?: string | undefined;
  type?: "article" | "profile" | undefined;
  noindex?: boolean | undefined;
  robots?: string | undefined;
  hideSectionLabel?: boolean | undefined;
  structuredData?:
    | Record<string, unknown>
    | Record<string, unknown>[]
    | undefined;
}

const {
  entry,
  tableOfContents,
  backHref = "/",
  backLabel = "Home",
  showAuthor = true,
  sectionLabel = "Article",
  seoTitle,
  seoDescription,
  canonical,
  type = "article",
  noindex = false,
  robots,
  hideSectionLabel = false,
  structuredData,
} = Astro.props as Props;

const readingTime = getReadingTime(entry.body);
const publishDate = formatDateToDisplay(entry.data.pubDate);
const publishDateIso = new Date(entry.data.pubDate).toISOString();

const updatedDateValue =
  "updatedDate" in entry.data
    ? entry.data.updatedDate
    : "updateDate" in entry.data
      ? entry.data.updateDate
      : undefined;

const updatedDate = updatedDateValue
  ? formatDateToDisplay(updatedDateValue as Date | string)
  : undefined;

const updatedDateIso = updatedDateValue
  ? new Date(updatedDateValue as Date | string).toISOString()
  : undefined;

const image =
  "ogImage" in entry.data && entry.data.ogImage?.url
    ? entry.data.ogImage.url
    : "image" in entry.data && entry.data.image?.url
      ? entry.data.image.url
      : undefined;

const imageAlt =
  "ogImage" in entry.data && entry.data.ogImage?.alt
    ? entry.data.ogImage.alt
    : "image" in entry.data && entry.data.image?.alt
      ? entry.data.image.alt
      : entry.data.title;

const resolvedSeoTitle =
  seoTitle ?? ("seoTitle" in entry.data ? entry.data.seoTitle : undefined);
const resolvedSeoDescription =
  seoDescription ??
  ("seoDescription" in entry.data ? entry.data.seoDescription : undefined);
const resolvedRobots =
  robots ?? ("robots" in entry.data ? entry.data.robots : undefined);

const entryNoindex =
  noindex || ("noindex" in entry.data ? Boolean(entry.data.noindex) : false);

const title =
  resolvedSeoTitle || `0b | ${entry.data.title}`;
const description = resolvedSeoDescription || entry.data.description;
const resolvedCanonical =
  canonical ??
  ("canonicalURL" in entry.data ? entry.data.canonicalURL : undefined);

const showCanonicalSource =
  typeof resolvedCanonical === "string" && /^https?:\/\//i.test(resolvedCanonical);

const tocItems: TocItem[] = tableOfContents
  .filter((heading) => heading.depth >= 2 && heading.depth <= 4)
  .map((heading) => ({
    text: heading.text,
    level: heading.depth,
    id: heading.slug,
  }));
---

<Layout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  canonical={resolvedCanonical}
  type={type}
  noindex={entryNoindex}
  robots={resolvedRobots}
  structuredData={structuredData}
  fixedNavbar={false}
  publishedTime={entry.data.pubDate}
  modifiedTime={updatedDateValue}
  section={sectionLabel}
  tags={"tags" in entry.data ? entry.data.tags : []}
>
  <div class="w-full flex justify-center px-5 sm:px-6 md:px-8 xl:px-0">
    <article class="pb-20 pt-4 space-y-6 w-full max-w-[800px] mx-auto xl:mx-0">
      <nav class="mb-10 flex items-center gap-5" aria-label="Article navigation">
        <a
          href={backHref}
          class="inline-flex items-center gap-1.5 text-xs font-semibold text-surface-500 transition-colors hover:text-surface-900 dark:text-surface-400 dark:hover:text-surface-200"
        >
          <i class="bx bx-arrow-back text-base" aria-hidden="true"></i>
          <span>Back to {backLabel.toLowerCase()}</span>
        </a>
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-xs font-medium text-surface-400 opacity-60 transition-colors hover:text-surface-900 hover:opacity-100 dark:text-surface-500 dark:hover:text-surface-200"
        >
          <i class="bx bx-home-alt-2 text-sm" aria-hidden="true"></i>
          <span>Back to home</span>
        </a>
      </nav>

      {
        image ? (
          <div class="relative w-full h-[350px] overflow-hidden rounded-xl">
            <img
              src={image}
              alt={"image" in entry.data ? entry.data.image?.alt || entry.data.title : entry.data.title}
              class="w-full h-full object-cover absolute inset-0 opacity-75"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        ) : null
      }

      <header class="space-y-4">
        {
          !hideSectionLabel && (
            <p class="text-xs font-medium uppercase tracking-widest text-surface-400 dark:text-surface-500">
              {sectionLabel}
            </p>
          )
        }

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tighter text-surface-900 dark:text-surface-100">
          {entry.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-surface-400 dark:text-surface-500">
          <div class="flex items-center gap-1.5">
            <i class="bx bx-calendar"></i>
            <time datetime={publishDateIso}>{publishDate}</time>
          </div>

          <div class="flex items-center gap-1.5">
            <i class="bx bx-time"></i>
            <span>{readingTime} min read</span>
          </div>

          {
            updatedDate && updatedDateIso ? (
              <div class="flex items-center gap-1.5">
                <i class="bx bx-refresh"></i>
                <time datetime={updatedDateIso}>Updated {updatedDate}</time>
              </div>
            ) : null
          }

          {
            showAuthor ? (
              <div class="flex items-center gap-1.5">
                <i class="bx bx-user"></i>
                <a
                  href="/me/ama"
                  class="hover:text-surface-900 dark:hover:text-surface-200 transition-colors"
                  rel="author"
                >
                  Kevin Bravo
                </a>
              </div>
            ) : null
          }

          {
            showCanonicalSource ? (
              <div class="flex items-center gap-1.5">
                <i class="bx bx-link-external"></i>
                <a
                  href={resolvedCanonical}
                  class="truncate max-w-48 hover:text-surface-900 dark:hover:text-surface-200 transition-colors"
                >
                  {resolvedCanonical}
                </a>
              </div>
            ) : null
          }
        </div>
      </header>

      <div
        class="prose prose-neutral max-w-none
          prose-headings:tracking-normal prose-headings:text-surface-950 dark:prose-headings:text-surface-100
          prose-h1:text-4xl prose-h1:font-extrabold prose-h1:leading-tight prose-h1:mt-12 prose-h1:mb-6
          prose-h2:text-3xl prose-h2:font-bold prose-h2:leading-tight prose-h2:mt-12 prose-h2:mb-5
          prose-h3:text-2xl prose-h3:font-bold prose-h3:leading-snug prose-h3:mt-10 prose-h3:mb-4
          prose-h4:text-xl prose-h4:font-semibold prose-h4:leading-snug prose-h4:mt-8 prose-h4:mb-3
          prose-h5:text-lg prose-h5:font-semibold prose-h5:leading-snug prose-h5:mt-7 prose-h5:mb-3
          prose-h6:text-base prose-h6:font-semibold prose-h6:leading-snug prose-h6:tracking-normal prose-h6:uppercase prose-h6:text-surface-600 dark:prose-h6:text-surface-300 prose-h6:mt-6 prose-h6:mb-2
          prose-p:text-surface-700 dark:prose-p:text-surface-400 prose-p:leading-relaxed
          prose-a:text-accent-600 dark:prose-a:text-accent-400 prose-a:no-underline hover:prose-a:underline hover:prose-a:text-accent-500 transition-colors
          prose-strong:text-surface-950 dark:prose-strong:text-surface-100 prose-strong:font-bold
          prose-em:text-surface-800 dark:prose-em:text-surface-200 prose-em:font-medium
          prose-blockquote:border-l-accent-500/40 dark:prose-blockquote:border-l-accent-400/35 prose-blockquote:bg-surface-50/70 dark:prose-blockquote:bg-surface-800/20 prose-blockquote:px-4 md:prose-blockquote:px-6 prose-blockquote:py-3 prose-blockquote:rounded-r-xl prose-blockquote:text-surface-800 dark:prose-blockquote:text-surface-200 prose-blockquote:italic prose-blockquote:font-medium
          prose-img:rounded-2xl prose-img:shadow-md prose-img:border prose-img:border-surface-100/60 dark:prose-img:border-surface-800/45
          prose-hr:border-surface-200/60 dark:prose-hr:border-surface-800/60
          prose-ul:list-disc prose-ol:list-decimal
          prose-li:marker:text-surface-400 dark:prose-li:marker:text-surface-600
          dark:prose-invert"
      >
        <slot />
      </div>


    </article>

    {tocItems.length > 0 ? <Toc items={tocItems} client:only="svelte" /> : null}
  </div>

  <ScrollUp />
</Layout>
