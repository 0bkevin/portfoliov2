---
import { getCollection, type CollectionEntry } from "astro:content";
import Swipper from "@components/blog/section/Swipper.svelte";

const blogs = await getCollection("blogs") as CollectionEntry<"blogs">[];

const sortedBlogs = blogs.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
---

<section class="py-24 md:py-32" id="articles">
  <div class="section-container mb-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-4">
      <div>
        <p class="section-heading">Blog</p>
        <h2 class="section-title">Articles</h2>
      </div>
      <a
        href="/0b"
        class="text-sm font-medium text-accent-500 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
      >
        View all &rarr;
      </a>
    </div>
  </div>
  <Swipper blogs={sortedBlogs} client:only="svelte"/>
</section>
