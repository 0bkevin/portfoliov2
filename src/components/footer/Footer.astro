---
import { footerLinks, socialIcons } from "./data.ts";
const currentYear = new Date().getFullYear();
---

<footer class="border-t dark:border-stone-950 bg-white dark:bg-stone-950 h-full w-full">
  <div
    class="flex flex-col items-center justify-center gap-8 px-4 py-12 md:py-16 w-full"
  >
    <a
      href="/"
      class="text-3xl font-bold tracking-tight transition-all duration-300 hover:text-green-500 dark:hover:text-green-400"
    >
      Kevin Bravo
    </a>
    <nav class="flex gap-6" aria-label="Footer navigation">
      {
        footerLinks.map(({ name, link }) => (
          <a
            href={link}
            class="text-slate-700 dark:text-gray-400 hover:text-green-500 text-sm font-medium transition-all duration-300"
          >
            {name}
          </a>
        ))
      }
    </nav>
    <div class="flex gap-4">
      {
        socialIcons.map(({ icon, link }) => (
          <a
            target="_blank"
            href={link}
            class={`hover:text-green-500 dark:hover:text-green-400 hover:scale-110 transition-all duration-300 text-2xl ${icon}`}
          />
        ))
      }
    </div>
    <p class="text-sm text-muted-foreground">
      Kevin Bravo. {currentYear} © All rights reserved
    </p>
  </div>
</footer>
