---
import { footerLinks, socialIcons } from "./data.ts";
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-surface-200 dark:border-surface-800">
  <div class="section-container py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="flex items-center gap-6">
        <a href="/" class="text-sm font-semibold tracking-tight text-surface-900 dark:text-surface-100">
          Kevin Bravo
        </a>
        <nav class="flex gap-5" aria-label="Footer navigation">
          {
            footerLinks.map(({ name, link }) => (
              <a
                href={link}
                class="text-xs text-surface-400 dark:text-surface-500 hover:text-surface-900 dark:hover:text-surface-200 transition-colors"
              >
                {name}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="flex items-center gap-6">
        <div class="flex gap-4">
          {
            socialIcons.map(({ icon, link, label }) => (
              <a
                target="_blank"
                href={link}
                rel="noopener noreferrer"
                aria-label={label}
                class={`text-surface-400 dark:text-surface-600 hover:text-surface-900 dark:hover:text-surface-200 transition-colors text-lg ${icon === "x" ? "inline-flex items-center" : icon}`}
              >
                {icon === "x" && (
                  <svg
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    class="h-[0.85em] w-[0.85em] fill-current"
                  >
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817-5.965 6.817H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
        <span class="text-xs text-surface-400 dark:text-surface-600">
          &copy; {currentYear}
        </span>
      </div>
    </div>
  </div>
</footer>
