---
import "./home.css";
---

<section class="section-container" id="home">
  <div class="min-h-[calc(100vh-3.5rem)] flex flex-col justify-center py-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="flex items-center gap-3 mb-8">
          <div class="h-px w-8 bg-accent-400"></div>
          <span class="text-sm font-medium text-surface-400 dark:text-surface-500 tracking-wide">Software Engineer</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-surface-900 dark:text-surface-100 mb-6">
          Kevin Bravo
        </h1>

        <p class="text-lg md:text-xl text-surface-500 dark:text-surface-400 leading-relaxed max-w-lg mb-12">
          Building core & blockchain infrastructure — backend systems, networking, smart contracts.
        </p>

        <div class="flex flex-wrap items-center gap-4">
          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-6 py-3 bg-surface-900 dark:bg-surface-100 text-white dark:text-surface-900 text-sm font-medium rounded-lg hover:bg-surface-800 dark:hover:bg-surface-200 transition-colors"
          >
            Get in touch
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="#about"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-surface-600 dark:text-surface-400 border border-surface-200 dark:border-surface-800 rounded-lg hover:border-surface-300 dark:hover:border-surface-700 hover:text-surface-900 dark:hover:text-surface-200 transition-colors"
          >
            About me
          </a>
        </div>

        <div class="flex items-center gap-5 mt-16 pt-8 border-t border-surface-200 dark:border-surface-800">
          <a href="https://twitter.com/0bkevin" target="_blank" rel="noopener noreferrer" class="text-surface-400 dark:text-surface-600 hover:text-surface-900 dark:hover:text-surface-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/0bkevin/" target="_blank" rel="noopener noreferrer" class="text-surface-400 dark:text-surface-600 hover:text-surface-900 dark:hover:text-surface-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/0bkevin/" target="_blank" rel="noopener noreferrer" class="text-surface-400 dark:text-surface-600 hover:text-surface-900 dark:hover:text-surface-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <div class="hidden lg:flex justify-center">
        <div class="home__blob"></div>
      </div>
    </div>
  </div>
</section>
