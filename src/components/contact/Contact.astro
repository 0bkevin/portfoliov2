---
import { contactData } from "./form/contactData";
import ContactForm from "./form/ContactForm.svelte";

const primary = contactData.find((c) => c.title === "Email");
const others = contactData.filter((c) => c.title !== "Email");
---

<section class="section-container py-24 md:py-32" id="contact">
  <div class="mb-20">
    <p class="section-heading">Contact</p>
    <h2 class="section-title">Let's build something</h2>
  </div>

  <div class="grid lg:grid-cols-[1fr_1.2fr] gap-16 lg:gap-24 items-start">
    <div class="flex flex-col gap-12">
      <p class="max-w-sm text-sm md:text-[15px] leading-relaxed text-surface-600 dark:text-surface-400">
        Have a project or a question? My inbox is open — I usually reply within a day.
      </p>

      {
        primary && (
          <a href={primary.link} class="group inline-flex items-baseline gap-2.5 w-fit">
            <span class="text-lg md:text-xl font-medium tracking-tight text-surface-900 dark:text-surface-100 transition-colors group-hover:text-accent-600 dark:group-hover:text-accent-400">
              {primary.content}
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-surface-400 dark:text-surface-600 transition-all duration-300 group-hover:text-accent-500 group-hover:translate-x-1" aria-hidden="true">
              <path d="m5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        )
      }

      <ul class="flex flex-col gap-3">
        {
          others.map((info) => (
            <li>
              <a
                href={info.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-3.5 w-fit"
              >
                <i
                  class={`bx bx${info.icon} text-base text-surface-400 dark:text-surface-500 transition-colors group-hover:text-accent-500 dark:group-hover:text-accent-400`}
                  aria-hidden="true"
                />
                <span class="text-sm text-surface-400 dark:text-surface-500 transition-colors group-hover:text-surface-900 dark:group-hover:text-surface-100">
                  {info.title}
                </span>
                <span class="text-sm text-surface-700 dark:text-surface-300 transition-colors group-hover:text-surface-900 dark:group-hover:text-surface-100">
                  {info.content}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <ContactForm client:only="svelte" />
  </div>
</section>
