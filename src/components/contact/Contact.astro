---
import { contactData } from "./form/contactData";
import ContactSocials from "./ContactSocials.astro";
import ContactForm from "./form/ContactForm.svelte";
---

<section class="section-container py-24 md:py-32" id="contact">
  <div class="mb-16">
    <p class="section-heading">Contact</p>
    <h2 class="section-title">Get in Touch</h2>
  </div>

  <div class="grid lg:grid-cols-2 gap-16 items-start">
    <div class="space-y-4">
      {
        contactData.map((info) => {
          return <ContactSocials {...info} />;
        })
      }
    </div>

    <div class="p-6 md:p-8 rounded-xl border border-surface-200 dark:border-surface-800">
      <ContactForm client:only="svelte" />
    </div>
  </div>
</section>
