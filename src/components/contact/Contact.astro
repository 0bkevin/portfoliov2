---
import { contactData } from "./form/contactData";
import ContactSocials from "./ContactSocials.astro";
import ContactForm from "./form/ContactForm.svelte";
---

<section class="relative min-h-screen w-full flex flex-col py-20 md:py-32" id="contact">
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto mb-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-stone-900 dark:text-stone-100">
        Get in Touch
      </h2>
      <p class="text-stone-500 dark:text-stone-400">
        Let's talk and build the future together.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 max-w-5xl mx-auto items-start">
      <div class="space-y-8">
        <div class="space-y-2">
          <h3 class="text-xl font-bold text-stone-800 dark:text-stone-100 uppercase tracking-wider text-sm">Talk to me</h3>
          <p class="text-stone-500 dark:text-stone-400 text-sm">Feel free to reach out through any of these channels.</p>
        </div>
        
        <div class="grid gap-4">
          {
            contactData.map((info) => {
              return <ContactSocials {...info} />;
            })
          }
        </div>
      </div>

      <div class="space-y-8">
        <div class="space-y-2">
          <h3 class="text-xl font-bold text-stone-800 dark:text-stone-100 uppercase tracking-wider text-sm">Send a message</h3>
          <p class="text-stone-500 dark:text-stone-400 text-sm">I'll get back to you as soon as possible.</p>
        </div>
        
        <div class="p-8 rounded-2xl bg-stone-50/50 dark:bg-stone-900/30 border border-stone-200/60 dark:border-stone-800/60 shadow-[0_4px_20px_-5px_rgba(0,0,0,0.05)] dark:shadow-none">
          <ContactForm client:only="svelte" />
        </div>
      </div>
    </div>
  </div>
</section>
