---
interface Props {
  title: string;
  icon: string;
  link: string;
  content: string;
}

const { title, icon, link, content } = Astro.props;
---

<a
  href={link}
  target="_blank"
  class="group flex items-center gap-4 py-4 border-b border-surface-100 dark:border-surface-800/50 last:border-b-0 hover:pl-2 transition-all"
>
  <div class="w-8 h-8 rounded-md bg-surface-100 dark:bg-surface-800 flex items-center justify-center shrink-0">
    <i class={`bx bx${icon} text-surface-500 dark:text-surface-400 text-sm`}></i>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-xs text-surface-400 dark:text-surface-500">{title}</p>
    <p class="text-sm font-medium text-surface-700 dark:text-surface-300 truncate">{content}</p>
  </div>
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-surface-300 dark:text-surface-700 group-hover:text-surface-500 dark:group-hover:text-surface-400 transition-colors shrink-0"><path d="m5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
</a>
