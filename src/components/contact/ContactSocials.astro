---
interface Props {
  title: string;
  icon: string;
  link: string;
  content: string;
}

const { title, icon, link, content } = Astro.props;
---

<a href={link} target="_blank" class="group block p-5 rounded-xl bg-stone-50/50 dark:bg-stone-900/30 border border-stone-200/60 dark:border-stone-800/60 shadow-[0_2px_10px_-3px_rgba(0,0,0,0.07)] dark:shadow-none hover:border-green-500/50 transition-colors">
  <div class="flex items-center gap-4">
    <div class="w-10 h-10 rounded-lg bg-stone-100 dark:bg-stone-800 flex items-center justify-center group-hover:bg-green-50 dark:group-hover:bg-green-900/20 transition-colors">
      <i class={`bx bx${icon} text-green-600 dark:text-green-500 text-xl`}></i>
    </div>
    <div class="flex-1">
      <h3 class="font-bold text-stone-800 dark:text-stone-100 text-sm uppercase tracking-wider">{title}</h3>
      <p class="text-xs text-stone-500 dark:text-stone-400">{content}</p>
    </div>
    <i class="bx bx-right-arrow-alt text-stone-400 group-hover:text-green-600 transition-colors text-xl"></i>
  </div>
</a>
