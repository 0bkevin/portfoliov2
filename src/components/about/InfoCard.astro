---
const ACHIEVEMENTS = [
  {
    title: "Experience",
    subtitle: `${new Date().getFullYear() - 2022} years of professional experience`,
    icon: "bx-award",
    index: 1,
  },
  {
    title: "Projects",
    subtitle: "5 projects completed",
    icon: "bx-briefcase-alt",
    index: 2,
  },
  {
    title: "Building",
    subtitle: "Constantly building and contributing",
    icon: "bx-code-alt",
    index: 3,
  },
];
---

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 w-full">
  {
    ACHIEVEMENTS.map(({ subtitle, icon, title }) => {
      return (
        <div class="flex flex-col items-start p-5 rounded-xl bg-stone-50/50 dark:bg-stone-900/30 border border-stone-200/60 dark:border-stone-800/60 shadow-[0_2px_10px_-3px_rgba(0,0,0,0.07)] dark:shadow-none">
          <i class={`bx ${icon} text-green-600 dark:text-green-500 text-xl mb-3`} />
          <h3 class="font-bold text-stone-800 dark:text-stone-100 text-sm mb-1 uppercase tracking-wider">{title}</h3>
          <p class="text-xs text-stone-500 dark:text-stone-400 leading-tight">{subtitle}</p>
        </div>
      );
    })
  }
</div>

<style>
  /* Removed old styles */
</style>