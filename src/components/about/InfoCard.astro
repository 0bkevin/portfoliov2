---
const ACHIEVEMENTS = [
  {
    title: "Experience",
    value: `${new Date().getFullYear() - 2022}+ years`,
  },
  {
    title: "Projects",
    value: "5 completed",
  },
  {
    title: "Status",
    value: "Building",
  },
];
---

<div class="grid grid-cols-3 gap-4">
  {
    ACHIEVEMENTS.map(({ value, title }) => (
      <div class="py-4 px-1 text-center border-r last:border-r-0 border-surface-200 dark:border-surface-800">
        <p class="text-lg font-bold tracking-tight text-surface-900 dark:text-surface-100">{value}</p>
        <p class="text-xs text-surface-400 dark:text-surface-500 mt-1">{title}</p>
      </div>
    ))
  }
</div>
