---
const EXPERIENCE_START_YEAR = 2021;
const EXPERIENCE_START_MONTH = 6;
const today = new Date();
const yearsOfExperience =
  today.getFullYear() -
  EXPERIENCE_START_YEAR -
  (today.getMonth() + 1 < EXPERIENCE_START_MONTH ? 1 : 0);

const ACHIEVEMENTS = [
  {
    title: "Experience",
    value: `${yearsOfExperience} years`,
  },
  {
    title: "Supported",
    value: "6 organizations",
    mobileValue: "6 orgs",
  },
  {
    title: "Available for new opportunities",
    mobileTitle: "Available",
    value: "Status",
  },
];
---

<div class="grid grid-cols-3 gap-4">
  {
    ACHIEVEMENTS.map(({ value, mobileValue, title, mobileTitle }) => (
      <div class="py-4 px-1 text-center border-r last:border-r-0 border-surface-200 dark:border-surface-800">
        <p class="text-lg font-bold tracking-tight text-surface-900 dark:text-surface-100">
          {mobileValue ? <span class="sm:hidden">{mobileValue}</span> : null}
          <span class={mobileValue ? "hidden sm:inline" : undefined}>{value}</span>
        </p>
        <p class="text-xs text-surface-400 dark:text-surface-500 mt-1">
          {mobileTitle ? <span class="sm:hidden">{mobileTitle}</span> : null}
          <span class={mobileTitle ? "hidden sm:inline" : undefined}>{title}</span>
        </p>
      </div>
    ))
  }
</div>
