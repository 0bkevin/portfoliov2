---
import Image from "../../../public/assets/photo-1.jpeg";
import Info from "./InfoCard.astro";
import ButtonLink from "@components/ButtonLink.astro";
---

<section
  class="relative min-h-screen w-full flex flex-col py-20 md:py-32"
  id="about"
>
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto mb-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-stone-900 dark:text-stone-100">
        About Me
      </h2>
      <p class="text-stone-500 dark:text-stone-400">
        Software Developer & MPA Student
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
      <div class="relative">
        <img 
          src={Image.src} 
          alt="Kevin Bravo" 
          class="rounded-2xl shadow-xl w-full max-w-sm mx-auto object-cover border border-stone-200 dark:border-stone-800"
        />
      </div>

      <div class="flex flex-col gap-10">
        <Info />

        <div class="space-y-6">
          <p class="text-stone-600 dark:text-stone-400 leading-relaxed">
            I’m <span class="text-stone-900 dark:text-stone-100 font-medium">Kevin</span>, a software developer and MPA student from Caracas, Venezuela. I specialize in building production-ready infrastructure that’s reliable, secure, and measurable.
          </p>
          <p class="text-stone-600 dark:text-stone-400 leading-relaxed">
            My technical focus lies in <span class="text-green-600 dark:text-green-500 font-medium">distributed systems, ZK proofs, and security</span>. With a strong foundation in Solidity and EVM-based chains, I enjoy tackling complex challenges in interoperability and embedded systems.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <ButtonLink
            target="_blank"
            link="https://drive.google.com/file/d/1XUAa1pM_F91Wp_SAPGe9lwWTTj_bVELI/view?usp=drivesdk"
          >
            <span class="flex items-center justify-center gap-2">
              Download CV
              <i class='bx bx-download text-xl'></i>
            </span>
          </ButtonLink>
          
          <ButtonLink link="/me/ama">
            <span class="flex items-center justify-center gap-2">
              Read AMA
              <i class="bx bx-message-rounded-dots text-xl"></i>
            </span>
          </ButtonLink>
        </div>
      </div>
    </div>
  </div>
</section>

