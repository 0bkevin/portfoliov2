---
import { getCollection, type CollectionEntry } from "astro:content";
import Swiper from "./Swiper.svelte";

const projects = (await getCollection("projects")) as CollectionEntry<"projects">[];

const sortedProjects = projects.sort(
  (a, b) => Number(b.data.pubYear) - Number(a.data.pubYear)
);
---

<section class="py-24 md:py-32" id="projects">
  <div class="section-container mb-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-4">
      <div>
        <p class="section-heading">Projects</p>
        <h2 class="section-title">Selected Work</h2>
      </div>
      <a
        href="/projects"
        class="text-sm font-medium text-accent-500 dark:text-accent-400 hover:text-accent-600 dark:hover:text-accent-300 transition-colors"
      >
        View all &rarr;
      </a>
    </div>
  </div>
  <Swiper projects={sortedProjects} client:only="svelte" />
</section>
