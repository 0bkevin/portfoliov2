---
import { TOOLS, LANGUAGES, FRAMEWORKS} from "./data";
import SkillCard from "./SkillCard.astro";
---

<section class="section-container py-24 md:py-32" id="skills">
  <div class="mb-16">
    <p class="section-heading">Skills</p>
    <h2 class="section-title">Technical Expertise</h2>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <SkillCard title="Languages" skills={LANGUAGES} />
    <SkillCard title="Frameworks" skills={FRAMEWORKS} />
    <SkillCard title="Tools & DevOps" skills={TOOLS} />
  </div>
</section>
