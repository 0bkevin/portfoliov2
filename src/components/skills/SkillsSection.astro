---
import { TOOLS, LANGUAGES, FRAMEWORKS} from "./data";
import SkillCard from "./SkillCard.astro";
---

<section class="relative min-h-screen w-full flex flex-col py-20 md:py-32" id="skills">
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto mb-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-stone-900 dark:text-stone-100">
        Technical Expertise
      </h2>
      <p class="text-stone-500 dark:text-stone-400">
        A focused overview of my technical stack and proficiency.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <SkillCard title="Languages" icon="bx bx-code-curly" skills={LANGUAGES} />
      <SkillCard title="Frameworks" icon="bx bx-layer" skills={FRAMEWORKS} />
      <SkillCard title="Tools & DevOps" icon="bx bx-wrench" skills={TOOLS} />
    </div>
  </div>
</section>
