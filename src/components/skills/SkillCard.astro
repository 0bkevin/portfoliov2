---
interface Props {
  title: string;
  skills: {
    name: string;
    level: string;
  }[];
}
const { title, skills } = Astro.props;
---

<div class="p-6 rounded-xl border border-surface-200 dark:border-surface-800">
  <h4 class="text-xs font-semibold uppercase tracking-widest text-surface-400 dark:text-surface-500 mb-6">
    {title}
  </h4>

  <div class="space-y-3">
    {
      skills.map(({ name, level }) => (
        <div class="flex items-center justify-between">
          <span class="text-sm text-surface-700 dark:text-surface-300">
            {name}
          </span>
          <span class={`text-[10px] font-medium uppercase tracking-wider ${
            level === 'Advanced' ? 'text-surface-900 dark:text-surface-100' :
            level === 'Intermediate' ? 'text-surface-500 dark:text-surface-400' :
            'text-surface-400 dark:text-surface-600'
          }`}>
            {level}
          </span>
        </div>
      ))
    }
  </div>
</div>
