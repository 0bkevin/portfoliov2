---
interface Props {
  title: string;
  icon: string;
  skills: {
    name: string;
    level: string;
  }[];
}
const { title, skills, icon } = Astro.props;
---

<div class="p-8 rounded-2xl bg-stone-50/50 dark:bg-stone-900/30 border border-stone-200/60 dark:border-stone-800/60 shadow-[0_4px_20px_-5px_rgba(0,0,0,0.05)] dark:shadow-none">
  <h4 class="text-xl font-bold mb-8 text-stone-800 dark:text-stone-100 flex items-center gap-2">
    <i class={`${icon} text-green-600 dark:text-green-500 text-lg`}></i>
    {title}
  </h4>

  <div class="grid grid-cols-1 gap-y-4">
    {
      skills.map(({ name, level }) => (
        <div class="flex items-center justify-between group">
          <span class="text-stone-600 dark:text-stone-400 group-hover:text-stone-900 dark:group-hover:text-stone-100 transition-colors">
            {name}
          </span>
          <span class="text-[10px] font-bold text-yellow-600 dark:text-yellow-500 uppercase tracking-widest">
            {level}
          </span>
        </div>
      ))
    }
  </div>
</div>
