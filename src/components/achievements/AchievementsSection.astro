---
const HONORS = [
  {
    date: "Sep 2025",
    title: "3rd Place Winner · EmprendeTECH Hackathon",
    issuer: "IESA",
    proof:
      "https://www.linkedin.com/in/0bkevin/overlay/Honor/887510572/treasury/?profileId=ACoAADSZ2zkB0ekFm1PJkO12A35maQbP-ni2b9w",
    summary:
      "Won third place with Planify in IESA's first EmprendeTECH Hackathon.",
  },
];

type Honor = (typeof HONORS)[number];

const grouped = HONORS.reduce<Record<string, Honor[]>>((acc, honor) => {
  const year = new Date(honor.date).getFullYear().toString();
  (acc[year] ??= []).push(honor);
  return acc;
}, {});

const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));

const monthOf = (date: string) =>
  new Date(date).toLocaleString("en-US", { month: "long" });
---

<section class="section-container py-24 md:py-32" id="honors">
  <div class="mb-16">
    <p class="section-heading">Honors &amp; Awards</p>
    <h2 class="section-title">Recognitions</h2>
  </div>

  <div class="flex flex-col gap-20 md:gap-28">
    {
      years.map((year) => (
        <div class="relative">
          <span
            aria-hidden="true"
            class="ghost-year block font-bold tracking-tighter leading-[0.85] select-none pointer-events-none text-[clamp(5rem,16vw,11rem)]"
          >
            {year}
          </span>

          <div class="relative -mt-6 md:-mt-10 flex flex-col gap-12 md:gap-14 pl-1 md:pl-2">
            {(grouped[year] ?? []).map((honor) => (
              <article class="group max-w-2xl">
                <a
                  href={honor.proof}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.25em] text-surface-400 dark:text-surface-500">
                    {honor.issuer}{" "}
                    <span class="text-surface-300 dark:text-surface-700">·</span>{" "}
                    {monthOf(honor.date)}
                  </p>

                  <h3 class="inline-flex items-baseline gap-3 text-2xl md:text-[28px] font-semibold tracking-tight text-surface-900 dark:text-surface-100 transition-colors group-hover:text-accent-600 dark:group-hover:text-accent-400">
                    <span>{honor.title}</span>
                    <i
                      class="bx bx-link-external shrink-0 text-base text-surface-300 dark:text-surface-700 opacity-0 -translate-x-1 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100 group-hover:text-accent-500"
                      aria-hidden="true"
                    />
                  </h3>

                  <p class="mt-4 text-sm md:text-[15px] leading-relaxed text-surface-600 dark:text-surface-400">
                    {honor.summary}
                  </p>
                </a>
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .ghost-year {
    color: transparent;
    -webkit-text-stroke: 1.5px #e5e5e5;
  }

  :global(.dark) .ghost-year {
    -webkit-text-stroke: 1.5px #262626;
  }
</style>
